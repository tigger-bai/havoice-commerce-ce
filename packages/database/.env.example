# Required for Prisma commands and database scripts.
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/portfolio_demo"
NODE_ENV="development"

# Required only when running the synthetic demo seed locally.
DEMO_USER_PASSWORD="replace-with-a-local-demo-password"

# Optional target for the manual role-promotion utility. A CLI argument may be used instead.
PROMOTE_EMAIL="admin@example.com"

