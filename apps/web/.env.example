# Required: local database and NextAuth server configuration.
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/portfolio_demo"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Client-exposed values. Never place secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_SUPPORT_EMAIL="contact@example.com"

# Server-only URLs used by the repayment route.
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"

# Optional, sandbox-only ECPay payment integration.
ECPAY_MERCHANT_ID="replace-with-sandbox-merchant-id"
ECPAY_HASH_KEY="replace-with-sandbox-hash-key"
ECPAY_HASH_IV="replace-with-sandbox-hash-iv"
ECPAY_ACTION_URL="https://sandbox-payment.example.com/checkout"
ECPAY_AIO_CHECKOUT_URL="https://sandbox-payment.example.com/checkout"
NEXT_PUBLIC_ECPAY_AIO_CHECKOUT_URL="https://sandbox-payment.example.com/checkout"

