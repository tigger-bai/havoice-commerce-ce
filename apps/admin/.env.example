# Required: local database and NextAuth server configuration.
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/portfolio_demo"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Client-exposed values. Never place secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Server-only URL used by logistics callbacks.
API_BASE_URL="http://localhost:4000"

# Optional image upload integration.
CLOUDINARY_CLOUD_NAME="replace-with-cloud-name"
CLOUDINARY_API_KEY="replace-with-api-key"
CLOUDINARY_API_SECRET="replace-with-api-secret"

# Optional SMTP integration. SMTP_FROM is required when sending in production.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="demo-sender@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="no-reply@example.com"

# Optional, sandbox-only ECPay payment and logistics integration.
ECPAY_MERCHANT_ID="replace-with-sandbox-merchant-id"
ECPAY_HASH_KEY="replace-with-sandbox-hash-key"
ECPAY_HASH_IV="replace-with-sandbox-hash-iv"
ECPAY_PLATFORM_ID=""
ECPAY_LOGISTICS_MERCHANT_ID="replace-with-sandbox-logistics-merchant-id"
ECPAY_LOGISTICS_HASH_KEY="replace-with-sandbox-logistics-hash-key"
ECPAY_LOGISTICS_HASH_IV="replace-with-sandbox-logistics-hash-iv"
ECPAY_LOGISTICS_URL="https://sandbox-logistics.example.com/create"
ECPAY_LOGISTICS_API_URL="https://sandbox-logistics.example.com/express/create"
ECPAY_LOGISTICS_PRINT_API_URL="https://sandbox-logistics.example.com/express/print"
ECPAY_LOGISTICS_SERVER_REPLY_URL="http://localhost:4000/api/orders/logistics-webhook"
ECPAY_LOGISTICS_SENDER_NAME="Demo Sender"
ECPAY_LOGISTICS_SENDER_PHONE="DEMO-PHONE"
ECPAY_LOGISTICS_SENDER_ZIP_CODE="000"
ECPAY_LOGISTICS_SENDER_ADDRESS="Demo City Sample Road"
ECPAY_POST_OFFICE_MODE="mock"
ECPAY_POST_OFFICE_DEFAULT_GOODS_WEIGHT="1"
ECPAY_POST_OFFICE_DEFAULT_RECEIVER_ZIP_CODE="000"

# Legacy aliases still read by the ECPay logistics code.
SENDER_NAME="Demo Sender"
SENDER_PHONE="DEMO-PHONE"

# Optional conventional post-office integration; disabled by default.
POST_OFFICE_ENABLED="false"
POST_OFFICE_API_URL="https://sandbox-post.example.com/api"
POST_OFFICE_CUSTOMER_ID="replace-with-sandbox-customer-id"
POST_OFFICE_API_KEY="replace-with-sandbox-api-key"
POST_OFFICE_SENDER_NAME="Demo Sender"
POST_OFFICE_SENDER_PHONE="DEMO-PHONE"
POST_OFFICE_SENDER_ADDRESS="Demo City Sample Road"

