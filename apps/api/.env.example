NODE_ENV="development"
API_PORT="4000"
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/portfolio_demo"

# Required URLs and production CORS allowlist.
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Server-only authentication secrets.
NEXTAUTH_SECRET="replace-with-the-same-secret-used-by-nextauth"
JWT_SECRET="replace-with-a-different-random-secret"
JWT_EXPIRES_IN="7d"

# Optional SMTP integration. SMTP_FROM is required when sending in production.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="demo-sender@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="no-reply@example.com"

# Optional, sandbox-only ECPay payment integration.
ECPAY_MERCHANT_ID="replace-with-sandbox-merchant-id"
ECPAY_HASH_KEY="replace-with-sandbox-hash-key"
ECPAY_HASH_IV="replace-with-sandbox-hash-iv"

# Optional, sandbox-only ECPay logistics integration.
ECPAY_LOGISTICS_MERCHANT_ID="replace-with-sandbox-logistics-merchant-id"
ECPAY_LOGISTICS_HASH_KEY="replace-with-sandbox-logistics-hash-key"
ECPAY_LOGISTICS_HASH_IV="replace-with-sandbox-logistics-hash-iv"
ECPAY_LOGISTICS_URL="https://sandbox-logistics.example.com/create"
ECPAY_MAP_URL="https://sandbox-logistics.example.com/map"
SENDER_NAME="Demo Sender"
SENDER_PHONE="DEMO-PHONE"

