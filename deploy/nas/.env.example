# Copy to deploy/nas/.env and replace every CHANGE_ME value.
# Never commit deploy/nas/.env.

# MySQL container settings (Docker internal only; port 3306 is not published)
MYSQL_DATABASE=havoice
MYSQL_USER=havoice
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
DATABASE_URL=mysql://havoice:CHANGE_ME_MYSQL_PASSWORD@mysql:3306/havoice

# LAN browser-accessible addresses (replace 192.168.1.100 with the NAS LAN IP)
NAS_HOST=192.168.1.100
PUBLIC_API_URL=http://192.168.1.100:3400
WEB_NEXTAUTH_URL=http://192.168.1.100:3100
ADMIN_NEXTAUTH_URL=http://192.168.1.100:3101
CORS_ORIGIN=http://192.168.1.100:3100,http://192.168.1.100:3101

# Docker-internal application URL is fixed in compose, not used by browsers:
# INTERNAL_API_URL=http://api:4000

# Required secrets (use long, random, different production values)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_NEXTAUTH_SECRET
DEMO_USER_PASSWORD=Demo2026Pass

# Public UI setting
NEXT_PUBLIC_SUPPORT_EMAIL=contact@example.com

# Optional mail settings (required only when production email delivery is used)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional Cloudinary settings (required only when admin uploads are used)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional ECPay settings (required when the related payment/logistics flow is used)
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ACTION_URL=
NEXT_PUBLIC_ECPAY_AIO_CHECKOUT_URL=
ECPAY_LOGISTICS_HASH_KEY=
ECPAY_LOGISTICS_HASH_IV=
ECPAY_MAP_URL=
