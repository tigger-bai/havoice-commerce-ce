# Portfolio Edition shared local environment overview.
# Copy only the values needed by each workspace; workspace-specific examples are authoritative.

NODE_ENV="development"
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/portfolio_demo"

API_PORT="4000"
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

NEXTAUTH_SECRET="replace-with-a-random-secret"
JWT_SECRET="replace-with-a-different-random-secret"
JWT_EXPIRES_IN="7d"

# Required only when running the synthetic demo seed locally.
DEMO_USER_PASSWORD="replace-with-a-local-demo-password"

